Route::get('/test-payin-total', function() {
    $total = \App\Models\Payment_request::where('status', 1)->where('data3', 1)->sum('amount');
    return "Total Payin Transactions: ₹" . number_format($total, 2);
});

Route::get('/test-wallet-balance/{userid}', function($userid) {
    $wallet = \App\Models\Wallet::where('userid', $userid)->first();
    $user = \App\Models\user::where('userid', $userid)->first();
    
    if(!$wallet) {
        return "Wallet not found for user: {$userid}";
    }
    
    if(!$user) {
        return "User not found: {$userid}";
    }
    
    return "Wallet Balance for {$user->name} ({$userid}):<br>" .
           "Payin Wallet: ₹" . number_format($wallet->payin, 2) . "<br>" .
           "Payout Wallet: ₹" . number_format($wallet->payout, 2) . "<br>" .
           "AEPS Wallet: ₹" . number_format($wallet->aeps, 2) . "<br>" .
           "Total Balance: ₹" . number_format($wallet->total_balance, 2) . "<br>" .
           "User Status: " . ($user->status == 1 ? 'Active' : 'Inactive') . "<br>";
});

Route::get('/wallet-audit/{userid}', function($userid) {
    $wallet = \App\Models\Wallet::where('userid', $userid)->first();
    $user = \App\Models\user::where('userid', $userid)->first();
    $payouts = \App\Models\PayoutRequest::where('userid', $userid)->get();
    
    $html = "<h2>Wallet Audit for {$user->name} ({$userid})</h2>";
    $html .= "<h3>Current Balances:</h3>";
    $html .= "Payin: ₹" . number_format($wallet->payin, 2) . " | ";
    $html .= "Payout: ₹" . number_format($wallet->payout, 2) . " | ";
    $html .= "AEPS: ₹" . number_format($wallet->aeps, 2) . " | ";
    $html .= "Total: ₹" . number_format($wallet->total_balance, 2) . "<br><br>";
    
    $html .= "<h3>Payout Transactions:</h3>";
    $totalSuccessful = 0;
    $totalFailed = 0;
    
    foreach($payouts as $payout) {
        $status = $payout->status == 1 ? 'Success' : ($payout->status == 2 ? 'Failed' : 'Pending');
        $total = $payout->amount + $payout->tax;
        $html .= "{$payout->transaction_id}: ₹{$total} ({$status})<br>";
        
        if($payout->status == 1) $totalSuccessful += $total;
        if($payout->status == 2) $totalFailed += $total;
    }
    
    $html .= "<br><strong>Total Successful: ₹{$totalSuccessful} | Total Failed: ₹{$totalFailed}</strong>";
    
    return $html;
});

Route::get('/check-all-payouts', function() {
    $payouts = \App\Models\PayoutRequest::all();
    
    $html = "<h2>All Payout Transactions</h2>";
    $html .= "<table border='1' style='border-collapse: collapse; width: 100%;'>";
    $html .= "<tr><th>ID</th><th>User ID</th><th>Transaction ID</th><th>Amount</th><th>Tax</th><th>Status</th><th>UTR</th><th>Created</th></tr>";
    
    foreach($payouts as $payout) {
        $statusText = $payout->status == 1 ? 'Success' : ($payout->status == 2 ? 'Failed' : 'Pending');
        $html .= "<tr>";
        $html .= "<td>{$payout->id}</td>";
        $html .= "<td>{$payout->userid}</td>";
        $html .= "<td>{$payout->transaction_id}</td>";
        $html .= "<td>₹" . number_format($payout->amount, 2) . "</td>";
        $html .= "<td>₹" . number_format($payout->tax, 2) . "</td>";
        $html .= "<td>{$statusText}</td>";
        $html .= "<td>{$payout->utr}</td>";
        $html .= "<td>{$payout->created_at}</td>";
        $html .= "</tr>";
    }
    
    $html .= "</table>";
    return $html;
});

Route::get('/test-payout-today', function() {
    $todayPayouts = \App\Models\PayoutRequest::where('status', 1)->where('created_at', '>=', date('Y-m-d') . ' 00:00:00')->get();
    $todayPayout = $todayPayouts->sum('amount');
    $todayPayoutTax = $todayPayouts->sum('tax');
    $totalTodayPayout = $todayPayout + $todayPayoutTax;
    
    $details = "Individual Payout Records:<br>";
    foreach($todayPayouts as $payout) {
        $details .= "ID: {$payout->id} | Transaction: {$payout->transaction_id} | Amount: ₹{$payout->amount} | Tax: ₹{$payout->tax} | Status: {$payout->status} | Created: {$payout->created_at}<br>";
    }
    
    return $details . "<br>" .
           "Today's Payout Amount: ₹" . number_format($todayPayout, 2) . "<br>" .
           "Today's Payout Tax: ₹" . number_format($todayPayoutTax, 2) . "<br>" .
           "Total Today Payout: ₹" . number_format($totalTodayPayout, 2) . "<br>" .
           "Date Range: " . date('Y-m-d') . " 00:00:00 to now";
});

Route::get('/test-payout-settlement10', function() {
    $payout = \App\Models\PayoutRequest::where('transaction_id', 'settlement10')->first();
    if($payout) {
        return "Settlement10 Details:<br>" .
               "ID: {$payout->id}<br>" .
               "Transaction ID: {$payout->transaction_id}<br>" .
               "Amount: ₹{$payout->amount}<br>" .
               "Tax: ₹{$payout->tax}<br>" .
               "Status: {$payout->status}<br>" .
               "UTR: {$payout->utr}<br>" .
               "Payout ID: {$payout->payout_id}<br>" .
               "Created: {$payout->created_at}<br>" .
               "Updated: {$payout->updated_at}<br>";
    } else {
        return "Settlement10 not found in payout_requests table";
    }
});

Route::get('/fix-settlement10', function() {
    $payout = \App\Models\PayoutRequest::where('transaction_id', 'settlement10')->first();
    if($payout) {
        // Update the payout record to reflect success
        $payout->status = 1; // Success
        $payout->utr = 'UTR24031545790'; // Latest UTR from PayVanta
        $payout->payout_id = 'settlement10'; // Set payout_id
        $payout->save();
        
        // Create transaction record for successful payout using DB::table
        \DB::table('transactions')->insert([
            'userid' => $payout->userid,
            'category' => 'payout',
            'type' => 'debit',
            'amount' => $payout->amount,
            'status' => 1,
            'data1' => $payout->transaction_id,
            'data2' => 'UTR24031545790', // UTR
            'data3' => '924010064720050', // Account Number
            'created_at' => now(),
            'updated_at' => now()
        ]);
        
        return "Settlement10 Fixed Successfully!<br>" .
               "Status: Updated to 1 (Success)<br>" .
               "UTR: Updated to UTR24031545790<br>" .
               "Payout ID: Set to settlement10<br>" .
               "Transaction Record: Created<br>";
    } else {
        return "Settlement10 not found in payout_requests table";
    }
});

