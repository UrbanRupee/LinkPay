Route::get('/', function () {
    try {
        if (session()->has('userlogin')) {
            return redirect('/dashboard');
        } elseif (session()->has('adminlogin')) {
            return redirect('/admin/dashboard');
        } else {
            return redirect('/login');
        }
    } catch (\Exception $e) {
        // Fallback to login if there's any session error
        return redirect('/login');
    }
});

